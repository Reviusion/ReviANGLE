LIBRARY opengl32
EXPORTS
    ; --- WGL (the minimum opengl32.dll must export) ---
    wglCreateContext       = wgl_wglCreateContext
    wglDeleteContext       = wgl_wglDeleteContext
    wglMakeCurrent         = wgl_wglMakeCurrent
    wglGetCurrentContext   = wgl_wglGetCurrentContext
    wglGetCurrentDC        = wgl_wglGetCurrentDC
    wglGetProcAddress      = wgl_wglGetProcAddress
    wglShareLists          = wgl_wglShareLists
    wglSwapBuffers         = wgl_wglSwapBuffers
    wglSwapIntervalEXT     = wgl_wglSwapIntervalEXT
    wglChoosePixelFormat   = wgl_wglChoosePixelFormat
    wglSetPixelFormat      = wgl_wglSetPixelFormat
    wglDescribePixelFormat = wgl_wglDescribePixelFormat
    wglGetPixelFormat      = wgl_wglGetPixelFormat

    ; --- common GL 1.1 entry points (forwarded to ANGLE libGLESv2) ---
    glClear                = gl_glClear
    glClearColor           = gl_glClearColor
    glClearDepth           = gl_glClearDepth
    glClearStencil         = gl_glClearStencil
    glDepthRange           = gl_glDepthRange
    glColorMask            = gl_glColorMask
    glCullFace             = gl_glCullFace
    glDepthMask            = gl_glDepthMask
    glDisable              = gl_glDisable
    glDrawArrays           = gl_glDrawArrays
    glDrawElements         = gl_glDrawElements
    glEnable               = gl_glEnable
    glFinish               = gl_glFinish
    glFlush                = gl_glFlush
    glFrontFace            = gl_glFrontFace
    glGetError             = gl_glGetError
    glGetIntegerv          = gl_glGetIntegerv
    glGetFloatv            = gl_glGetFloatv
    glGetBooleanv          = gl_glGetBooleanv
    glGetString            = gl_glGetString
    glHint                 = gl_glHint
    glIsEnabled            = gl_glIsEnabled
    glLineWidth            = gl_glLineWidth
    glPixelStorei          = gl_glPixelStorei
    glPolygonMode          = gl_glPolygonMode
    glPolygonOffset        = gl_glPolygonOffset
    ; GL 3.x desktop functions absent in GLES — provide stubs to prevent NULL crashes
    glDrawElementsBaseVertex = gl_glDrawElementsBaseVertex
    glPrimitiveRestartIndex  = gl_glPrimitiveRestartIndex
    glProvokingVertex        = gl_glProvokingVertex
    glReadPixels           = gl_glReadPixels
    glScissor              = gl_glScissor
    glStencilFunc          = gl_glStencilFunc
    glStencilMask          = gl_glStencilMask
    glStencilOp            = gl_glStencilOp
    glViewport             = gl_glViewport
    glBlendFunc            = gl_glBlendFunc
    glBlendEquation        = gl_glBlendEquation
    glBlendFuncSeparate    = gl_glBlendFuncSeparate
    glDepthFunc            = gl_glDepthFunc

    glActiveTexture        = gl_glActiveTexture
    glBindTexture          = gl_glBindTexture
    glDeleteTextures       = gl_glDeleteTextures
    glGenTextures          = gl_glGenTextures
    glTexImage2D           = gl_glTexImage2D
    glTexSubImage2D        = gl_glTexSubImage2D
    glTexParameteri        = gl_glTexParameteri
    glTexParameterf        = gl_glTexParameterf
    glCompressedTexImage2D = gl_glCompressedTexImage2D
    glGenerateMipmap       = gl_glGenerateMipmap
    glGetStringi           = gl_glGetStringi

    ; --- GL 2.0+ / GLES 3.0 wrappers (defined in gl_proxy_ext.cpp) ---
    glReadBuffer              = gl_glReadBuffer
    glDrawBuffers             = gl_glDrawBuffers
    glCopyTexImage2D          = gl_glCopyTexImage2D
    glCopyTexSubImage2D       = gl_glCopyTexSubImage2D
    glGetTexParameteriv       = gl_glGetTexParameteriv
    glGetTexParameterfv       = gl_glGetTexParameterfv

    glGenBuffers              = gl_glGenBuffers
    glBindBuffer              = gl_glBindBuffer
    glBufferData              = gl_glBufferData
    glBufferSubData           = gl_glBufferSubData
    glDeleteBuffers           = gl_glDeleteBuffers
    glMapBufferRange          = gl_glMapBufferRange
    glUnmapBuffer             = gl_glUnmapBuffer
    glIsBuffer                = gl_glIsBuffer
    glGetBufferParameteriv    = gl_glGetBufferParameteriv

    glGenVertexArrays         = gl_glGenVertexArrays
    glBindVertexArray         = gl_glBindVertexArray
    glDeleteVertexArrays      = gl_glDeleteVertexArrays
    glIsVertexArray           = gl_glIsVertexArray

    glCreateShader            = gl_glCreateShader
    glDeleteShader            = gl_glDeleteShader
    glShaderSource            = gl_glShaderSource
    glCompileShader           = gl_glCompileShader
    glGetShaderiv             = gl_glGetShaderiv
    glGetShaderInfoLog        = gl_glGetShaderInfoLog
    glGetShaderSource         = gl_glGetShaderSource
    glIsShader                = gl_glIsShader

    glCreateProgram           = gl_glCreateProgram
    glDeleteProgram           = gl_glDeleteProgram
    glAttachShader            = gl_glAttachShader
    glDetachShader            = gl_glDetachShader
    glLinkProgram             = gl_glLinkProgram
    glUseProgram              = gl_glUseProgram
    glGetProgramiv            = gl_glGetProgramiv
    glGetProgramInfoLog       = gl_glGetProgramInfoLog
    glValidateProgram         = gl_glValidateProgram
    glIsProgram               = gl_glIsProgram
    glBindAttribLocation      = gl_glBindAttribLocation
    glGetAttribLocation       = gl_glGetAttribLocation
    glGetActiveAttrib         = gl_glGetActiveAttrib
    glGetActiveUniform        = gl_glGetActiveUniform

    glGetUniformLocation      = gl_glGetUniformLocation
    glUniform1f               = gl_glUniform1f
    glUniform2f               = gl_glUniform2f
    glUniform3f               = gl_glUniform3f
    glUniform4f               = gl_glUniform4f
    glUniform1i               = gl_glUniform1i
    glUniform2i               = gl_glUniform2i
    glUniform3i               = gl_glUniform3i
    glUniform4i               = gl_glUniform4i
    glUniform1fv              = gl_glUniform1fv
    glUniform2fv              = gl_glUniform2fv
    glUniform3fv              = gl_glUniform3fv
    glUniform4fv              = gl_glUniform4fv
    glUniform1iv              = gl_glUniform1iv
    glUniform2iv              = gl_glUniform2iv
    glUniform3iv              = gl_glUniform3iv
    glUniform4iv              = gl_glUniform4iv
    glUniformMatrix2fv        = gl_glUniformMatrix2fv
    glUniformMatrix3fv        = gl_glUniformMatrix3fv
    glUniformMatrix4fv        = gl_glUniformMatrix4fv

    glVertexAttribPointer     = gl_glVertexAttribPointer
    glEnableVertexAttribArray = gl_glEnableVertexAttribArray
    glDisableVertexAttribArray= gl_glDisableVertexAttribArray
    glVertexAttrib1f          = gl_glVertexAttrib1f
    glVertexAttrib2f          = gl_glVertexAttrib2f
    glVertexAttrib3f          = gl_glVertexAttrib3f
    glVertexAttrib4f          = gl_glVertexAttrib4f
    glVertexAttrib1fv         = gl_glVertexAttrib1fv
    glVertexAttrib2fv         = gl_glVertexAttrib2fv
    glVertexAttrib3fv         = gl_glVertexAttrib3fv
    glVertexAttrib4fv         = gl_glVertexAttrib4fv

    glGenFramebuffers         = gl_glGenFramebuffers
    glBindFramebuffer         = gl_glBindFramebuffer
    glFramebufferTexture2D    = gl_glFramebufferTexture2D
    glFramebufferRenderbuffer = gl_glFramebufferRenderbuffer
    glCheckFramebufferStatus  = gl_glCheckFramebufferStatus
    glDeleteFramebuffers      = gl_glDeleteFramebuffers
    glIsFramebuffer           = gl_glIsFramebuffer
    glBlitFramebuffer         = gl_glBlitFramebuffer
    glGetFramebufferAttachmentParameteriv = gl_glGetFramebufferAttachmentParameteriv

    glGenRenderbuffers        = gl_glGenRenderbuffers
    glBindRenderbuffer        = gl_glBindRenderbuffer
    glRenderbufferStorage     = gl_glRenderbufferStorage
    glRenderbufferStorageMultisample = gl_glRenderbufferStorageMultisample
    glDeleteRenderbuffers     = gl_glDeleteRenderbuffers
    glIsRenderbuffer          = gl_glIsRenderbuffer

    glStencilFuncSeparate     = gl_glStencilFuncSeparate
    glStencilMaskSeparate     = gl_glStencilMaskSeparate
    glStencilOpSeparate       = gl_glStencilOpSeparate
    glSampleCoverage          = gl_glSampleCoverage
