*.obj
*.pch
*.pdb
*.idb
*.ilk
*.tlog
*.lastbuildstate
*.unsuccessfulbuild
*.metagen
*.exp
*.lib
Debug/
Release/
x64/
x86/
Win32/
ARM/
ARM64/

# --- VS solution-level ---
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.props.user

# --- Editor / IDE ---
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- ANGLE prebuilt binaries (download separately, see docs/BUILDING.md) ---
# Keep them in releases only, not in source.
angle/
libEGL.dll
libGLESv2.dll
d3dcompiler_47.dll

# --- Game files (never commit GD installation) ---
GeometryDash.exe
*.gmd
*.dat
CCGameManager.dat
CCLocalLevels.dat
Resources/

# --- Runtime / generated ---
angle_log.txt
shader_cache/
plist_cache/
fbo_cache/
tuner_history.csv
last_screenshot.png
*.zip
*.7z
!release/*.zip

# --- Local PowerShell helper scripts (not part of project) ---
ai_tuner.ps1
auto_iter.ps1
auto_test.ps1
manual_tune.ps1
analyze_log.ps1

# --- Personal / private ---
.env
*.local
secrets.*
